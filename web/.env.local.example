NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

MONGODB_URI=mongodb://localhost:27017/doppeldash

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=doppeldash_unsigned

# Microsoft Outlook integration (Phase 8)
OUTLOOK_CLIENT_ID=your_azure_app_client_id
OUTLOOK_CLIENT_SECRET=your_azure_app_client_secret
OUTLOOK_WEBHOOK_SECRET=doppeldash-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Vision API for OCR (Phase 8)
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# Anthropic Claude API for AI message generation (Phase 8)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Email notifications via Resend (Phase 9)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=DoppelDash <no-reply@yourdomain.com>
